FROM golang:1.22-alpine AS builder

WORKDIR /app

# Install git for go modules
RUN apk add --no-cache git ca-certificates

# Copy go.mod only first — go.sum will be generated by tidy
COPY go.mod ./

# Copy full source so tidy can resolve all imports
COPY . .

# Generate go.sum and download all dependencies
RUN go mod tidy && go mod download

# Build
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-w -s" \
    -o kubevision-api \
    ./cmd/server

# ── Runtime image ──────────────────────────────────────────────────────────────
FROM alpine:3.19

RUN apk --no-cache add ca-certificates tzdata

WORKDIR /app

COPY --from=builder /app/kubevision-api .

EXPOSE 8080

ENV GIN_MODE=release
ENV PORT=8080

ENTRYPOINT ["./kubevision-api"]
